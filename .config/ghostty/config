macos-titlebar-style = hidden
background-opacity = 0.75
# background-blur-radius = 10
window-padding-x = 10
window-padding-y = 8

# og themes for customization
# /Applications/Ghostty.app/Contents/Resources/ghostty/themes
theme = tokyonight-black-bg.conf

font-size = 15
font-thicken = true
mouse-hide-while-typing = true

# neovide-like cursor shader
custom-shader = ~/.config/ghostty/shaders/ghostty-cursor-shaders/cursor_warp.glsl
