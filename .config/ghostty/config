macos-titlebar-style = hidden
background-opacity = 0.75
background-blur-radius = 13
window-padding-x = 10
window-padding-y = 8
theme = Zenbones Dark
font-size = 15
font-thicken = true
mouse-hide-while-typing = true

# neovide-like cursor shader
custom-shader = ~/.config/ghostty/shaders/ghostty-cursor-shaders/cursor_warp.glsl
